# ===========================================
# 风铃通知 - 环境变量配置
# ===========================================
# 复制此文件为 .env 并填入配置

# ===========================================
# OAuth2 认证配置（至少配置一个 provider）
# ===========================================

# --- GitHub OAuth ---
# 在 https://github.com/settings/developers 创建 OAuth App
# 回调 URL 设置为: http://localhost:3456/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# 可选：自定义回调 URL（部署到生产环境时必填）
# GITHUB_CALLBACK_URL=https://your-domain.com/auth/github/callback

# --- Google OAuth (预留) ---
# 在 https://console.cloud.google.com/apis/credentials 创建 OAuth 2.0 客户端
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- QQ OAuth (预留) ---
# 在 https://connect.qq.com/ 创建应用
# QQ_CLIENT_ID=
# QQ_CLIENT_SECRET=

# ===========================================
# JWT 密钥（安全注意事项）
# ===========================================
# 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 重要: 务必设置为一个64位的随机十六进制字符串
# 如果未设置，服务器每次重启都会生成新的随机密钥，导致所有已签发的 JWT 失效
# 这意味着用户每次服务器重启都需要重新登录
JWT_SECRET=

# ===========================================
# 服务器配置
# ===========================================
PORT=3456
NODE_ENV=development

# ===========================================
# 部署平台配置
# ===========================================

# 部署到 Workers/EdgeOne 时需要配置
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# EdgeOne 外部存储 API（可选）
# STORAGE_API_URL=https://your-storage-api.example.com
