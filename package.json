{
  "name": "notice-hub",
  "version": "2.0.0",
  "description": "风铃通知 - 分层式通知管理系统（Express/Cloudflare/EdgeOne/Netlify）",
  "main": "cmd/serverApp/main.js",
  "scripts": {
    "start": "node cmd/serverApp/main.js",
    "dev": "node cmd/serverApp/main.js",
    "dev:worker": "wrangler dev",
    "deploy:worker": "wrangler deploy",
    "build:worker": "node scripts/buildWorker.js",
    "build:edgeone": "node scripts/buildEdgeOne.js",
    "bump:version": "node scripts/bumpVersion.js",
    "deploy": "npm run build && wrangler deploy",
    "preview": "npm run build && wrangler dev"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "hono": "^4.0.0",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "serverless-http": "^3.2.0",
    "wrangler": "^4.107.0"
  }
}
