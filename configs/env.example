# ===========================================
# 风铃通知 (notice-hub) - 环境变量配置
# ===========================================
# 复制此文件到项目根目录 .env 并填入配置

# ===========================================
# OAuth2 认证配置（至少配置一个 provider）
# ===========================================

# --- GitHub OAuth ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=

# ===========================================
# JWT 密钥
# ===========================================
# 生成: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 务必配置，否则服务器重启后所有已登录用户需要重新登录
JWT_SECRET=

# ===========================================
# 服务器配置
# ===========================================
PORT=3456
NODE_ENV=development
